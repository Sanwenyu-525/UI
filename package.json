{
  "name": "ui-components",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform UI component system",
  "scripts": {
    "build": "pnpm -r run build",
    "build:tokens": "pnpm --filter @ui/tokens run build",
    "build:css": "pnpm --filter @ui/css run build",
    "build:react": "pnpm --filter @ui/react run build",
    "build:react-native": "pnpm --filter @ui/react-native run build",
    "build:codegen": "pnpm --filter @ui/token-codegen run build",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm -r run clean",
    "test": "pnpm --filter @ui/react run test",
    "test:watch": "pnpm --filter @ui/react run test:watch",
    "test:coverage": "pnpm --filter @ui/react run test:coverage"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  }
}
